{
  "name": "qa-securian-financial",
  "version": "1.0.0",
  "author": "ajaiaugustine14 <ajaiaugustine94@gmail.com>",
  "description": "E2E test automation for Securian Financial Retirement Calculator using WebdriverIO and Jasmine",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "webdriver",
    "webdriverio",
    "jasmine",
    "e2e",
    "automation",
    "securian",
    "retirement-calculator"
  ],
  "scripts": {
    "lint": "eslint .",
    "test": "npm run typecheck && npm run lint && npm run test:local",
    "typecheck": "tsc --noEmit",
    "test:local": "wdio run wdio.local.conf.ts",
    "test:sauce": "wdio run wdio.sauce.conf.ts"
  },
  "devDependencies": {
    "@types/jasmine": "^6.0.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/eslint": "^0.1.1",
    "@wdio/globals": "9.27.0",
    "@wdio/jasmine-framework": "9.27.0",
    "@wdio/local-runner": "9.27.0",
    "@wdio/sauce-service": "9.27.0",
    "@wdio/spec-reporter": "9.27.0",
    "eslint": "^10.0.0",
    "typescript": "^6.0.2",
    "wdio-html-nice-reporter": "^8.1.7",
    "webdriverio": "9.27.0"
  }
}
